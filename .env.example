# Database Configuration
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=

# Environment
ENVIRONMENT=

# Google OAuth (OIDC)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback
ALLOWED_GOOGLE_HD=ucla.edu,g.ucla.edu

# JWT
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# S3 / Object Storage (used by image upload APIs)
AWS_REGION=
# If left blank, boto3 will use environment/profile/role credential chain.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
S3_BUCKET_NAME=
# Pre-signed S3 upload URL TTL (seconds)
S3_PRESIGNED_URL_EXPIRES_SECONDS=600
